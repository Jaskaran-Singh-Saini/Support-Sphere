# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave POSTGRES_HOST empty for SQLite in local dev)
POSTGRES_DB=support_sphere
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=
POSTGRES_PORT=5432

# Redis / Channels
REDIS_HOST=127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Field-level encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
